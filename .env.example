APP_ENV=development
APP_PORT=9292
DATABASE_URL=postgres://<db_user>:<db_password>@db:5432/potorix
REDIS_URL=redis://redis:6379/0
HYPERVISOR_URI=qemu:///system
HYPERVISOR_MODE=virsh
VM_DISK_DIR=/var/lib/libvirt/images
ISO_LIBRARY_DIR=/var/lib/libvirt/boot
VNC_PROXY_TARGET_HOST=host.docker.internal
AUTH_TOKENS=admin:<admin_api_key>,operator:<operator_api_key>,viewer:<viewer_api_key>
